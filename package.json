{
  "name": "solfaces",
  "version": "2.2.0",
  "description": "Deterministic wallet avatars and names for the Solana ecosystem. SHA-256 name derivation, zero-dependency trait engine with React, vanilla JS, and server-side rendering support.",
  "author": "https://github.com/jorger3301",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorger3301/solfaces.git"
  },
  "homepage": "https://github.com/jorger3301/SolFaces#readme",
  "keywords": [
    "solana",
    "avatar",
    "wallet",
    "identity",
    "profile",
    "pfp",
    "generative",
    "deterministic",
    "svg",
    "react",
    "web3",
    "defi",
    "ai-agent",
    "mcp",
    "tool-use",
    "function-calling",
    "name-generator",
    "deterministic-name",
    "sha256",
    "solnames"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla/index.d.ts",
      "import": "./dist/vanilla/index.js",
      "require": "./dist/vanilla/index.cjs"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js",
      "require": "./dist/themes/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "require": "./dist/agent/index.cjs"
    },
    "./names": {
      "types": "./dist/names/index.d.ts",
      "import": "./dist/names/index.js",
      "require": "./dist/names/index.cjs"
    },
    "./cdn": "./dist/solfaces.cdn.global.js"
  },
  "bin": {
    "solfaces-mcp": "dist/agent/mcp-server.cjs"
  },
  "files": [
    "dist",
    "python",
    "SKILL.md",
    "reference",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.0",
    "eslint": "^10.0.2",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "sideEffects": false
}
